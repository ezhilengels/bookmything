# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — visible in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose in client code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — NEVER expose to client, server-side only
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# API credentials — from Razorpay dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Webhook secret — set in Razorpay dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Sender address — must be a verified domain in Resend
EMAIL_FROM=noreply@yourdomain.com

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL — no trailing slash
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
# Secret token to protect the /api/cron/* endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ─── Invite Tokens ────────────────────────────────────────────────────────────
# Secret used to sign staff invite tokens (HMAC-SHA256)
# Falls back to CRON_SECRET if not set. For best security, set a separate key.
# Generate with: openssl rand -hex 32
INVITE_TOKEN_SECRET=your-invite-token-secret-here
